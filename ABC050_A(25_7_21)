/*Problem Statement
Joisino wants to evaluate the formula 
"A op B". Here, A and B are integers, and the binary operator op is either + or -. 
Your task is to evaluate the formula instead of her.

Constraints
1≦A,B≦10 
9
 
op is either + or -.*/


#include<stdio.h>

int main()
{
    int A,B;
    char op;

    do{
        scanf("%d %c %d", &A, &op, &B);
    }while(op!='+'&&op!='-');

    if(op=='+')
    {
        printf("%d", A+B);

    }
    else if(op=='-')
    {
        printf("%d", A-B);
    }
    

    return 0;
    
}